# ============================================================
# Shadow Brain — Production Environment Configuration
# Domain: brain.mr-imperfect.online
# Product: Cognova AI Platform
# Mode: production (Node.js + Docker + Nginx + PostgreSQL + Redis)
# ============================================================
# ⚠️  NEVER commit this file to version control. Keep chmod 600.
# ============================================================

# ------------------------------------------------------------------
# Domain & Public URLs (Required for Production)
# ------------------------------------------------------------------
DOMAIN=brain.mr-imperfect.online
NEXT_PUBLIC_APP_URL=https://brain.mr-imperfect.online

# ------------------------------------------------------------------
# Branding (Cognova AI Platform)
# ------------------------------------------------------------------
NEXT_PUBLIC_PRODUCT_NAME=Cognova
NEXT_PUBLIC_TAGLINE=AI Business Partner
NEXT_PUBLIC_DESCRIPTION=Elite AI CEO Office System

# ------------------------------------------------------------------
# Core AI Providers (Required)
# ------------------------------------------------------------------
# OpenAI API key for GPT-4, GPT-4o, o1, etc.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pinecone vector database for RAG / memory
PINECONE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PINECONE_INDEX=shadow-brain

# ------------------------------------------------------------------
# Database — Self-Hosted PostgreSQL 17 (via Docker Compose)
# ------------------------------------------------------------------
POSTGRES_USER=shadowbrain
# Change to a strong 32+ character random password before first deploy
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_32_CHARS_MIN
POSTGRES_DB=shadowbrain

# Supabase-compatible URL (points to PostgREST inside Docker network)
NEXT_PUBLIC_SUPABASE_URL=http://postgrest:3001
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_STRONG_PASSWORD_32_CHARS_MIN

# Direct connection string used by the app container
DATABASE_URL=postgres://shadowbrain:REPLACE_WITH_STRONG_PASSWORD_32_CHARS_MIN@postgres:5432/shadowbrain

# ------------------------------------------------------------------
# Redis 7 — BullMQ Job Queues & Session Cache
# ------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ------------------------------------------------------------------
# Observability (Recommended for Production)
# ------------------------------------------------------------------
LANGSMITH_API_KEY=ls-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LOG_LEVEL=info

# ------------------------------------------------------------------
# Cloudflare Integrations (Optional — for DNS, R2, Workers)
# ------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------
# Google Workspace Integrations (Optional)
# ------------------------------------------------------------------
GMAIL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GMAIL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Service account JSON for Google Sheets / Drive API (Phase 4 AI Partner)
# Paste the entire JSON key file content as a single line, or mount a file
GOOGLE_SERVICE_ACCOUNT_JSON=

# ------------------------------------------------------------------
# Notion Integration (Optional — for knowledge base sync)
# ------------------------------------------------------------------
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------
# Slack Notifications (Optional — for alerts and digests)
# ------------------------------------------------------------------
SLACK_WEBHOOK_URL=YOUR_SLACK_WEBHOOK_URL_HERE

# ------------------------------------------------------------------
# CRM Integrations (Optional — Phase 4 AI Business Partner)
# ------------------------------------------------------------------
# CRM_TYPE: mock | hubspot | salesforce
CRM_TYPE=mock
CRM_MOCK_DELAY_MS=0

# HubSpot (used when CRM_TYPE=hubspot)
HUBSPOT_API_KEY=
HUBSPOT_BASE_URL=https://api.hubapi.com

# Salesforce (used when CRM_TYPE=salesforce)
SALESFORCE_DOMAIN=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REFRESH_TOKEN=

# ------------------------------------------------------------------
# Feature Phases (Enable progressively as you scale)
# ------------------------------------------------------------------
# Phase 1: AI Assistant (chat, reasoning, task generation)
ENABLE_PHASE1=true
# Phase 2: Digital Shadow (memory, preferences, RAG pipeline)
ENABLE_PHASE2=true
# Phase 3: Chief of Staff (RSS, digests, BI, job queues) — requires 4GB+ RAM
ENABLE_PHASE3=false
# Phase 4: AI Business Partner (experiments, CRM, Sheets, audit)
ENABLE_PHASE4=false
# Phase 5: AI CEO Office (KG, workflows, SIEM, briefings) — requires 8GB+ RAM
ENABLE_PHASE5=false

# ------------------------------------------------------------------
# Backup & Optional Services
# ------------------------------------------------------------------
# S3 bucket for automated database backups (scripts/backup.sh)
# S3_BACKUP_BUCKET=cognova-backups-brain

# pgAdmin (enable by adding --profile tools to docker compose up)
# PGADMIN_EMAIL=admin@brain.mr-imperfect.online
# PGADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_32_CHARS_MIN

# ------------------------------------------------------------------
# Deployment & Runtime (Auto-set by Docker Compose, rarely changed)
# ------------------------------------------------------------------
# NODE_ENV=production
# PORT=3000
# HOSTNAME=0.0.0.0
# NEXT_TELEMETRY_DISABLED=1
