# ============================================================
# Shadow Brain — Production Environment Template
# Domain: brain.mr-imperfect.online
# Product: Cognova AI Platform
# Copy to .env and fill in all required values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------------
# Domain & Public URLs (Required for Production)
# ------------------------------------------------------------------
DOMAIN=brain.mr-imperfect.online
NEXT_PUBLIC_APP_URL=https://brain.mr-imperfect.online

# ------------------------------------------------------------------
# Branding (Optional — falls back to Cognova defaults)
# ------------------------------------------------------------------
NEXT_PUBLIC_PRODUCT_NAME=Cognova
NEXT_PUBLIC_TAGLINE=AI Business Partner
NEXT_PUBLIC_DESCRIPTION=Elite AI CEO Office System

# ------------------------------------------------------------------
# Core AI Providers (Required)
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-...
PINECONE_API_KEY=...
PINECONE_INDEX=shadow-brain

# ------------------------------------------------------------------
# Database (Self-Hosted PostgreSQL)
# ------------------------------------------------------------------
POSTGRES_USER=shadowbrain
POSTGRES_PASSWORD=ChangeThisStrongPassword123!
POSTGRES_DB=shadowbrain

# Supabase compatibility (for self-hosted, use local values)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=ChangeThisStrongPassword123!

# Direct database URL (used by app container internally)
DATABASE_URL=postgres://shadowbrain:ChangeThisStrongPassword123!@postgres:5432/shadowbrain

# ------------------------------------------------------------------
# Redis (Required for BullMQ queues)
# ------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ------------------------------------------------------------------
# Observability (Optional)
# ------------------------------------------------------------------
LANGSMITH_API_KEY=...
LOG_LEVEL=info

# ------------------------------------------------------------------
# Cloud Integrations (Optional)
# ------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_API_TOKEN=...
GMAIL_CLIENT_ID=...
GMAIL_CLIENT_SECRET=...

# Google Service Account JSON (for Google Sheets / Drive API — Phase 4)
# Paste the full JSON content of your service account key file here
GOOGLE_SERVICE_ACCOUNT_JSON=

# ------------------------------------------------------------------
# Notion Integration (Optional)
# ------------------------------------------------------------------
NOTION_TOKEN=secret_...

# ------------------------------------------------------------------
# Slack Notifications (Optional)
# ------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ------------------------------------------------------------------
# CRM Integrations (Optional — Phase 4 AI Business Partner)
# ------------------------------------------------------------------
# CRM_TYPE: mock | hubspot | salesforce
CRM_TYPE=mock
CRM_MOCK_DELAY_MS=0

# HubSpot (used when CRM_TYPE=hubspot)
HUBSPOT_API_KEY=...
HUBSPOT_BASE_URL=https://api.hubapi.com

# Salesforce (used when CRM_TYPE=salesforce)
SALESFORCE_DOMAIN=...
SALESFORCE_CLIENT_ID=...
SALESFORCE_CLIENT_SECRET=...
SALESFORCE_REFRESH_TOKEN=...

# ------------------------------------------------------------------
# Feature Phases (true/false)
# ------------------------------------------------------------------
ENABLE_PHASE1=true
ENABLE_PHASE2=true
ENABLE_PHASE3=false
ENABLE_PHASE4=false
ENABLE_PHASE5=false

# ------------------------------------------------------------------
# Backup & Optional Services
# ------------------------------------------------------------------
# S3_BACKUP_BUCKET=your-backup-bucket
# PGADMIN_EMAIL=admin@brain.mr-imperfect.online
# PGADMIN_PASSWORD=ChangeThisToo!
